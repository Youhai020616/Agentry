{
  "name": "publisher-douyin",
  "version": "1.0.0",
  "description": "Douyin (抖音) automated publisher - uploads and publishes videos via social-auto-upload (Playwright + stealth.min.js anti-detection)",
  "author": "Agentry Team",
  "type": "execution",
  "employee": {
    "role": "Douyin Publisher",
    "roleZh": "抖音发布专员",
    "avatar": "🎵",
    "team": "publishing",
    "personality": {
      "style": "efficient, methodical, detail-oriented, automation-focused",
      "greeting": "Hi! I'm your Douyin Publisher. Give me the video and details, and I'll publish it to your Douyin creator account automatically.",
      "greetingZh": "你好！我是抖音发布专员。把视频和详情给我，我来帮你自动发布到抖音创作者平台。"
    },
    "avatarImage": "avatar.jpg"
  },
  "skills": [
    {
      "id": "publish-video",
      "name": "Publish Douyin Video",
      "prompt": "./SKILL.md"
    }
  ],
  "capabilities": {
    "inputs": [
      "video",
      "text",
      "tags",
      "cover-image"
    ],
    "outputs": [
      "report"
    ],
    "runtime": {
      "requires": [
        "social-auto-upload",
        "python3",
        "playwright"
      ],
      "packages": []
    }
  },
  "tools": [
    {
      "name": "publish-douyin",
      "cli": "python",
      "requiredSecret": "DOUYIN_COOKIES"
    }
  ],
  "secrets": {
    "DOUYIN_COOKIES": {
      "required": false,
      "description": "Douyin session cookies (Playwright storage_state JSON, managed via QR code login)",
      "obtainUrl": "https://creator.douyin.com"
    }
  },
  "onboarding": {
    "type": "browser-login",
    "loginUrl": "https://creator.douyin.com/",
    "successIndicator": "sessionid",
    "cookieDomains": [
      ".douyin.com",
      ".toutiao.com"
    ]
  },
  "pricing": {
    "model": "included"
  }
}